        <div class="menu-item">
          <div class="menu-emoji">☕</div>
          <div class="menu-info">
            <div class="menu-name">Filter Coffee</div>
            <div class="menu-cat">Beverages</div>
          </div>
          <div class="menu-sales">
            <div class="menu-sales-val">62 sold</div>
            <div class="menu-bar-wrap"><div class="menu-bar" style="width:100%"></div></div>
          </div>
        </div>
        <div class="menu-item">
          <div class="menu-emoji">🫔</div>
          <div class="menu-info">
            <div class="menu-name">Chole Bhature</div>
            <div class="menu-cat">Snacks</div>
          </div>
          <div class="menu-sales">
            <div class="menu-sales-val">29 sold</div>
            <div class="menu-bar-wrap"><div class="menu-bar" style="width:60%"></div></div>
          </div>
        </div>
      </div>
 
    </div>
 
    <!-- Bottom Row -->
    <div class="bottom-grid">
 
      <!-- Revenue Chart -->
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Weekly Revenue</div>
            <div class="card-sub">Mon – Sun · ₹ in thousands</div>
          </div>
          <span style="font-size:11px;color:var(--gold);">This week</span>
        </div>
        <div class="chart-container">
          <div class="bar-col">
            <div class="bar" style="height:52px;"></div>
            <div class="bar-lbl">Mon</div>
          </div>
          <div class="bar-col">
            <div class="bar" style="height:68px;"></div>
            <div class="bar-lbl">Tue</div>
          </div>
          <div class="bar-col">
            <div class="bar" style="height:44px;"></div>
            <div class="bar-lbl">Wed</div>
          </div>
          <div class="bar-col">
            <div class="bar" style="height:76px;"></div>
            <div class="bar-lbl">Thu</div>
          </div>
          <div class="bar-col">
            <div class="bar" style="height:60px;"></div>
            <div class="bar-lbl">Fri</div>
          </div>
          <div class="bar-col">
            <div class="bar active" style="height:80px;"></div>
            <div class="bar-lbl" style="color:var(--gold);">Sat</div>
          </div>
          <div class="bar-col">
            <div class="bar" style="height:34px;opacity:0.35;"></div>
            <div class="bar-lbl">Sun</div>
          </div>
        </div>
        <div style="display:flex;justify-content:space-between;margin-top:14px;">
          <div>
            <div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;">Week Total</div>
            <div style="font-family:'Playfair Display',serif;font-size:20px;color:var(--cream);margin-top:2px;">₹1,14,820</div>
          </div>
          <div style="text-align:right;">
            <div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;">vs Last Week</div>
            <div style="font-size:16px;color:#7ec96e;margin-top:2px;">▲ 9.2%</div>
          </div>
        </div>
      </div>
 
      <!-- Category Donut -->
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Sales by Category</div>
            <div class="card-sub">Today's breakdown</div>
          </div>
        </div>
        <div class="donut-wrap">
          <svg class="donut-svg" width="120" height="120" viewBox="0 0 120 120">
            <!-- donut segments via stroke-dasharray -->
            <circle cx="60" cy="60" r="45" fill="none" stroke="var(--bg3)" stroke-width="18"/>
            <!-- Main: 38% -->
            <circle cx="60" cy="60" r="45" fill="none" stroke="var(--gold)" stroke-width="18"
              stroke-dasharray="107.5 175.5" stroke-dashoffset="0" transform="rotate(-90 60 60)"/>
            <!-- Snacks: 24% -->
            <circle cx="60" cy="60" r="45" fill="none" stroke="var(--accent)" stroke-width="18"
              stroke-dasharray="67.9 215.1" stroke-dashoffset="-107.5" transform="rotate(-90 60 60)"/>
            <!-- Beverages: 20% -->
            <circle cx="60" cy="60" r="45" fill="none" stroke="var(--blue)" stroke-width="18"
              stroke-dasharray="56.5 226.5" stroke-dashoffset="-175.4" transform="rotate(-90 60 60)"/>
            <!-- Desserts: 18% -->
            <circle cx="60" cy="60" r="45" fill="none" stroke="#6a8a5a" stroke-width="18"
              stroke-dasharray="50.9 232.1" stroke-dashoffset="-231.9" transform="rotate(-90 60 60)"/>
            <text x="60" y="56" text-anchor="middle" fill="var(--cream)" font-family="Playfair Display,serif" font-size="16">284</text>
            <text x="60" y="70" text-anchor="middle" fill="var(--muted)" font-family="DM Sans,sans-serif" font-size="9">orders</text>
          </svg>
          <div class="donut-legend">
            <div class="legend-row"><div class="legend-dot" style="background:var(--gold)"></div><div class="legend-label">Main Course</div><div class="legend-val">38%</div></div>
            <div class="legend-row"><div class="legend-dot" style="background:var(--accent)"></div><div class="legend-label">Snacks</div><div class="legend-val">24%</div></div>
            <div class="legend-row"><div class="legend-dot" style="background:var(--blue)"></div><div class="legend-label">Beverages</div><div class="legend-val">20%</div></div>
            <div class="legend-row"><div class="legend-dot" style="background:#6a8a5a"></div><div class="legend-label">Desserts</div><div class="legend-val">18%</div></div>
          </div>
        </div>
      </div>
 
      <!-- Quick Actions & Staff -->
      <div style="display:flex;flex-direction:column;gap:16px;">
 
        <div class="card" style="padding:18px;">
          <div class="card-header">
            <div class="card-title">Quick Actions</div>
          </div>
          <div class="actions-grid">
            <button class="action-btn" onclick="window.location.href='/Additems'">
              <span class="a-icon">➕</span>
              <span class="a-label">Add Item  </span>
              <span class="a-sub">New menu entry</span>
            </button>
            <button class="action-btn" onclick="window.location.href='/admin/orders'">
              <span class="a-icon">📋</span>
              <span class="a-label">New Order</span>
              <span class="a-sub">Manual entry</span>
            </button>
            <button class="action-btn" onclick="window.location.href='/admin/inventory'">

  <span class="a-icon">📦</span>

  <span class="a-label">Stock Alert</span>

  <span class="a-sub">
    <%= lowStockItems.length %> items low
  </span>

</button>
            <button class="action-btn">
              <span class="a-icon">🖨️</span>
              <span class="a-label">Print Report</span>
              <span class="a-sub">Daily summary</span>
            </button>
          </div>
        </div>
 
        <div class="card" style="padding:18px;">
          <div class="card-header">
            <div class="card-title">Staff on Duty</div>
          </div>
          <div class="staff-item">
            <div class="staff-av" style="background:rgba(201,150,58,.2);color:var(--gold-lt);">RS</div>
            <div>
              <div class="staff-name">Rajan Singh</div>
              <div class="staff-role">Head Chef</div>
            </div>
            <div class="staff-status"><span class="badge badge-green">On duty</span></div>
          </div>
          <div class="staff-item">
            <div class="staff-av" style="background:rgba(58,104,152,.2);color:#7ab0e0;">MV</div>
            <div>
              <div class="staff-name">Meena Varma</div>
              <div class="staff-role">Cashier</div>
            </div>
            <div class="staff-status"><span class="badge badge-green">On duty</span></div>
          </div>
          <div class="staff-item">
            <div class="staff-av" style="background:rgba(160,64,48,.2);color:#e07060;">PK</div>
            <div>
              <div class="staff-name">Prakash Kumar</div>
              <div class="staff-role">Server</div>
            </div>
            <div class="staff-status"><span class="badge badge-amber">Break</span></div>
          </div>
        </div>
 
      </div>
    </div>
 
  </div><!-- /content -->
</main>
 
</body>
</html>